{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Secretbank",
  "version": "0.1.0-pre17",
  "identifier": "app.secretbank",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Secretbank",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:8787 https://secretbank.app https://services.nvd.nist.gov https://api.github.com https://haveibeenpwned.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "secretbank",
          "app.secretbank",
          "com.googleusercontent.apps.522239075495-b72lmghgcgeei7ddm9h2957le92c8oo1"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1NEFGRDhDMTI3MTgxOEUKUldTT2dYRVNqUDFLeFZkb1ZuZ3pEcEVaTFNmUTJvemZPYU1JT0JvYnBUNDF3ZGNZTDhjc3BzNE0K",
      "endpoints": ["https://secretbank.app/api/latest"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
