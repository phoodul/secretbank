{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "api-vault",
  "version": "0.1.0",
  "identifier": "com.phoodul.apivault",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "api-vault",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:8787 https://api-vault.app https://services.nvd.nist.gov https://api.github.com https://haveibeenpwned.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["apivault"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1NEFGRDhDMTI3MTgxOEUKUldTT2dYRVNqUDFLeFZkb1ZuZ3pEcEVaTFNmUTJvemZPYU1JT0JvYnBUNDF3ZGNZTDhjc3BzNE0K",
      "endpoints": ["https://github.com/phoodul/api-vault/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
