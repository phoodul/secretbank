# ===========================================
# Desktop App (Tauri + Rust + React)
# 이 파일을 .env로 복사한 후 값을 입력하세요.
# cp .env.example .env
# ===========================================

# --- App ---
VITE_APP_NAME=MyDesktopApp
VITE_API_BASE_URL=http://localhost:8080

# --- 업데이트 서버 (사용 시) ---
# TAURI_UPDATER_ENDPOINT=https://your-update-server.com
# TAURI_UPDATER_PUBKEY=your-public-key

# --- 외부 서비스 (필요 시) ---
# DATABASE_URL=sqlite:///path/to/local.db
# SENTRY_DSN=https://...@sentry.io/...

# --- Tier 2 리서치 MCP (글로벌 ~/.bashrc에 설정 권장) ---
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
