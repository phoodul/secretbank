# NOTE: pnpm 9 는 .npmrc 의 `ignore-workspace` 항목을 무시한다 (CLI flag
# `--ignore-workspace` 만 지원). 그래서 deploy-relay.yml 의 install 단계는
# 직접 flag 를 붙인다. 이 파일은 로컬 개발자가 ee/secretbank-relay 안에서
# `pnpm install` 호출 시에도 같은 의도를 명시하기 위한 placeholder 다.
#
# pnpm 이 미래 버전에서 .npmrc 의 ignore-workspace 도 honour 하게 되면
# 자동으로 적용된다.
ignore-workspace=true
