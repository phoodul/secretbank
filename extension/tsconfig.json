{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["vitest/globals", "@testing-library/jest-dom", "chrome"]
  },
  "include": [
    "entrypoints/**/*.ts",
    "entrypoints/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "styles/**/*.ts",
    "wxt.config.ts",
    "tailwind.config.ts",
    "vitest.config.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "playwright.config.ts",
    "tests/e2e/**/*.ts",
    "tests/web-ext/**/*.ts",
    ".wxt/types/imports.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
