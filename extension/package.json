{
  "name": "@secretbank/extension",
  "private": true,
  "version": "0.1.0-pre12",
  "description": "Secretbank browser extension — save, fill, and manage secrets across the web",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build && wxt build --browser firefox",
    "build:chromium": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip && wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@secretbank/shared": "workspace:*",
    "@wxt-dev/i18n": "^0.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "wxt": "^0.20.26"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.43",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.6",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^4.6.0",
    "@wxt-dev/module-react": "^1.2.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "postcss-rem-to-responsive-pixel": "^7.0.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "vitest": "^4.1.8"
  }
}
