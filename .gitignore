dist/
build/

# env
.env
.env.local
.env.*
!.env.example

# tauri
# Cargo.lock 은 의도적으로 커밋한다 (바이너리/앱 = 재현 빌드 + GitHub 의존성
# 그래프 등록으로 cargo Dependabot 보안 알림 활성화). CI 는 --locked 로 검증.

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# testing
coverage/

# playwright e2e
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# typescript
*.tsbuildinfo

# claude code (personal)
CLAUDE.local.md
.claude/settings.local.json

# Personal / private notes (not shared)
user_docs/
user_research/
work-log/
# docs/ 는 버전 관리 대상 — project-decisions, architecture, task, implementation_plan, progress, work-log 등
# 필요 시 특정 파일만 제외하려면 아래에 개별 경로 추가

# antigravity (personal)
.antigravity/

# tauri generated schemas
src-tauri/gen/
.claude/state/

# ee/ — Enterprise Edition (Cloudflare Workers 릴레이 등)
ee/**/node_modules/
ee/**/dist/
ee/**/.wrangler/
ee/**/.dev.vars
ee/**/wrangler.toml.local

# vscode-extension (M21)
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/*.vsix

# jetbrains-plugin (M22)
jetbrains-plugin/.gradle/
jetbrains-plugin/build/
jetbrains-plugin/.idea/
jetbrains-plugin/gradle/
jetbrains-plugin/gradlew
jetbrains-plugin/gradlew.bat

# Marketing 영상 — landing site 의 demo 섹션이 직접 host (api-vault.app/media/*.webm).
# 3개 demo (lock-screen / charter-issuance / recovery-flow) 합 ~3.5 MB → commit 가능.
# 새로 만들 때: `pnpm capture:demo` 로 재생성 (Playwright + tauri mock)
# media/*.webm
media/*.mp4
# site/media/ 는 deploy-site.yml 이 build 시 cp -v media/*.webm site/media/ 로 stage.
# 로컬 dev 서버에서 video 미리보려면 같은 명령으로 직접 stage 하라.
site/media/

# browser extension (M24-E)
extension/node_modules/
extension/dist/
extension/.wxt/
extension/.output/

# logo source materials (작업 자료 — 실제 사용은 src-tauri/icons + extension/public/icon + site/og-image.png)
logo_image/

# dogfooding 용 평문 vault export (절대 커밋 금지 — 실제 비밀번호 포함)
1PasswordExport-*.csv
*-export-*.csv
